# Copy to .env and adjust. Never commit .env.

# --- Database (strict local vs live) ---
# Local development: SQLite file under prisma/ (gitignored). Never point this at production.
DATABASE_URL="file:./prisma/local.db"
# Omit or set to `local` on laptops and CI. Set to `live` ONLY on the production host.
HEALTHNET_DATABASE_ROLE=local

# Production server example (in /var/www/healthnet/.env only — not on your laptop):
# DATABASE_URL="file:./data/live.db"
# HEALTHNET_DATABASE_ROLE=live

# --- Auth / bootstrap (optional) ---
# HEALTHNET_ADMIN_EMAIL=admin@example.com
# HEALTHNET_ADMIN_PASSWORD=...

# --- Resend OTP email ---
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="Ayur Health <noreply@your-domain.com>"
# APP_BASE_URL=https://your-domain.com
# OTP_SECRET=long-random-secret
# OTP_TTL_MINUTES=10
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SECONDS=60

# --- M-Pesa Daraja (production or sandbox) ---
# If Safaricom gave you TWO apps (Lipa na M-Pesa for STK + a separate B2C app), set split keys.
# Otherwise use only MPESA_CONSUMER_KEY / MPESA_CONSUMER_SECRET for both.
# MPESA_ENV=production
#
# STK Push (M-Pesa Express / Paybill) — app with "Lipa na M-Pesa Production"
# MPESA_STK_CONSUMER_KEY=
# MPESA_STK_CONSUMER_SECRET=
# MPESA_STK_SHORTCODE=           # e.g. Paybill / till short code
# MPESA_STK_PASSKEY=             # from Daraja → Lipa na M-Pesa → Online Passkey
# MPESA_STK_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/stk/callback
#
# B2C withdrawals — app with B2C product enabled
# MPESA_B2C_CONSUMER_KEY=
# MPESA_B2C_CONSUMER_SECRET=
# MPESA_B2C_SHORTCODE=
# MPESA_B2C_INITIATOR_NAME=      # API operator username
# MPESA_B2C_SECURITY_CREDENTIAL= # encrypted with Safaricom public cert
# MPESA_B2C_COMMAND_ID=BusinessPayment
# MPESA_B2C_RESULT_URL=https://your-domain.com/api/payments/mpesa/b2c/result
# MPESA_B2C_TIMEOUT_URL=https://your-domain.com/api/payments/mpesa/b2c/timeout
#
# Optional: single pair for both flows (ignored if STK_/B2C_ keys above are set)
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
#
# If set, append ?token=VALUE to all three callback URLs in Daraja and here:
# MPESA_CALLBACK_TOKEN=
